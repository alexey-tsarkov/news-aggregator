{% extends 'base.html.twig' %}

{% block title %}Свежие новости - {{ parent() }}{% endblock %}

{% block body %}
<div class="container p-4">
    <h1 class="mb-4">Свежие новости ⚡</h1>

    <div class="mb-4">
        <form action="{{ path('app_news_search') }}" class="w-100">
            <input type="search" class="form-control" name="q" placeholder="Искать" tabindex="1">
        </form>
    </div>

    {% if news %}
        <div class="row row-cols-1 row-cols-md-2 g-4 mb-4">
            {% for post in news %}
                <div class="col">
                    {{ component('News:Card', {news: post}) }}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="mb-4">Новости еще не подъехали...</p>
    {% endif %}
</div>
{% endblock %}
